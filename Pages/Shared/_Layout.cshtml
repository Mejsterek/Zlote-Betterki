<!DOCTYPE html>
<html lang="pl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Złote Betterki</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" />
    <link rel="stylesheet" href="~/Betterki.styles.css" />
    <link rel="shortcut icon" href="~/favcicon.ico" />
</head>
<body class="app-shell">
    <header class="app-header">
        <nav class="navbar navbar-dark app-nav">
            <div class="container-fluid app-nav-inner">
                <a class="navbar-brand d-flex align-items-center gap-3" asp-area="" asp-page="/Index">
                    <img src="~/Zote_Betterki.png" alt="Złote Betterki" class="app-logo" />
                    <span class="brand-text">Złote Betterki</span>
                </a>
            </div>
        </nav>
    </header>

    <main class="app-main">
        <div class="container app-container">
            @RenderBody()
        </div>
    </main>

    <footer class="app-footer">
        <div class="container d-flex justify-content-between flex-wrap gap-2">
            <span>&copy; 2026 Złote Betterki</span>
            <span>Dawid "Mejster" Senouci</span>
        </div>
    </footer>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
